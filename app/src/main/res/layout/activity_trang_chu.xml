<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#DDE3EC">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="230dp"
            android:background="@drawable/bg_header_gradient"
            android:orientation="vertical"
            android:padding="24dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/tvWelcome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Xin chào"
                    android:textColor="@android:color/white"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvLogout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="Đăng xuất"
                    android:textColor="@android:color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <TextView
                android:id="@+id/tvRole"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Vai trò"
                android:textColor="#E8ECFF"
                android:textSize="15sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:gravity="center"
                android:text="TRANG CHỦ HỆ THỐNG\nQUẢN LÝ THƯ VIỆN"
                android:textAllCaps="true"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="-28dp"
            android:background="@drawable/bg_body_top_round"
            android:orientation="vertical"
            android:padding="20dp">

            <include
                android:id="@+id/layoutSach"
                layout="@layout/item_menu_trangchu_sach" />

            <include
                android:id="@+id/layoutMuonTra"
                layout="@layout/item_menu_trangchu_muontra" />

            <include
                android:id="@+id/layoutTheThuVien"
                layout="@layout/item_menu_trangchu_thethuvien" />

            <include
                android:id="@+id/layoutDocGia"
                layout="@layout/item_menu_trangchu_docgia" />

            <include
                android:id="@+id/layoutTacGia"
                layout="@layout/item_menu_trangchu_tacgia" />

            <include
                android:id="@+id/layoutTheLoai"
                layout="@layout/item_menu_trangchu_theloai" />

            <include
                android:id="@+id/layoutNXB"
                layout="@layout/item_menu_trangchu_nxb" />

            <include
                android:id="@+id/layoutNgonNgu"
                layout="@layout/item_menu_trangchu_ngonngu" />

            <include
                android:id="@+id/layoutKeSach"
                layout="@layout/item_menu_trangchu_kesach" />

            <include
                android:id="@+id/layoutLop"
                layout="@layout/item_menu_trangchu_lop" />

            <include
                android:id="@+id/layoutKhoa"
                layout="@layout/item_menu_trangchu_khoa" />

            <include
                android:id="@+id/layoutNhanVien"
                layout="@layout/item_menu_trangchu_nhanvien" />

            <include
                android:id="@+id/layoutThongKe"
                layout="@layout/item_menu_trangchu_thongke" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>